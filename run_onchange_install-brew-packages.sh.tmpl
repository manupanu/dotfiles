{{- $os := .chezmoi.os -}}
{{- if hasKey . "targetOS" -}}
{{- $os = .targetOS -}}
{{- end -}}
{{- if eq $os "darwin" -}}
#!/bin/sh
set -eu

if ! command -v brew >/dev/null 2>&1; then
  echo "brew not found, skipping Brewfile install"
  exit 0
fi

brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile"
{{- end -}}
